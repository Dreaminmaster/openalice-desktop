{
  "productName": "OpenAlice Desktop",
  "version": "0.1.0-alpha.1",
  "identifier": "com.dreaminmaster.openalice-desktop",
  "build": {
    "frontendDist": "../src/build",
    "devUrl": "http://localhost:1420"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/16x16.png",
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/512x512.png",
      "icons/1024x1024.png"
    ],
    "resources": []
  },
  "windows": [
    {
      "title": "OpenAlice Desktop",
      "width": 1200,
      "height": 800,
      "resizable": true
    }
  ],
  "security": {
    "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost; style-src 'self' 'unsafe-inline'"
  }
}
