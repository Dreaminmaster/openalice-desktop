{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenAlice Desktop",
  "version": "0.1.1-alpha.1",
  "identifier": "com.dreaminmaster.openalice-desktop",
  "build": {
    "frontendDist": "../src/build",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "OpenAlice Desktop",
        "width": 1200,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ]
  }
}
